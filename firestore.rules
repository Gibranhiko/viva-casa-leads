rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
          && request.auth.token.email == 'gibranhiko@gmail.com';
    }

    match /leads/{leadId} {
      allow create: if request.resource.data.nombre is string
                   && request.resource.data.nombre.size() > 0
                   && request.resource.data.nombre.size() < 200
                   && request.resource.data.whatsapp is string
                   && request.resource.data.whatsapp.matches('[0-9]{10}')
                   && (!('comentarios' in request.resource.data)
                       || request.resource.data.comentarios.size() < 500)
                   && (!('infonavit' in request.resource.data)
                       || request.resource.data.infonavit is map);
      allow read: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /seller-leads/{leadId} {
      allow create: if request.resource.data.nombre is string
                   && request.resource.data.nombre.size() > 0
                   && request.resource.data.nombre.size() < 200
                   && request.resource.data.whatsapp is string
                   && request.resource.data.whatsapp.matches('[0-9]{10}')
                   && (!('comentarios' in request.resource.data)
                       || request.resource.data.comentarios.size() < 500)
                   && (!('fotoPaths' in request.resource.data)
                       || request.resource.data.fotoPaths.size() <= 5);
      allow read: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /mail/{mailId} {
      allow read, write: if false;
    }
  }
}
